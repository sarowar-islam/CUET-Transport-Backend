# Copy this file to .env.local for local development.
# .env.local is ignored by git and safe for machine-specific secrets.

# Database connection (Neon/PostgreSQL)
DATABASE_URL=postgresql://username:password@host:5432/database?sslmode=require
# Optional overrides (if omitted, username/password can be parsed from DATABASE_URL)
DATABASE_USERNAME=
DATABASE_PASSWORD=

# JWT configuration
JWT_SECRET=change-me-to-a-very-long-random-secret-change-me-to-a-very-long-random-secret
JWT_EXPIRATION_MS=86400000

# Frontend allowed origins (local + deployed Netlify app)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://cuet-transport-section.netlify.app
